{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "deplox/miravia-sdk",
    "type": "library",
    "description": "PHP SDK for the Miravia marketplace API.",
    "keywords": ["miravia", "saloon", "sdk", "marketplace"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Jona Goldman",
            "email": "jonagoldman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/cache": "^13.0",
        "illuminate/config": "^13.0",
        "illuminate/log": "^13.0",
        "illuminate/support": "^13.0",
        "saloonphp/cache-plugin": "^3.0",
        "saloonphp/pagination-plugin": "^2.3",
        "saloonphp/rate-limit-plugin": "^2.5",
        "saloonphp/saloon": "^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Deplox\\MiraviaSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Deplox\\MiraviaSdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "stan": "phpstan analyse --memory-limit=512M"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Deplox\\MiraviaSdk\\MiraviaSdkServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
