{
  "permissions": {
    "allow": [
      "Bash(composer test *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/graphify-bash-check.sh"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/graphify-read-check.sh"
          }
        ]
      }
    ]
  }
}
